{
    "name": "rushing/laravel-commerce",
    "description": "The shared money-in engine for the ecosystem: a neutral Order -> Payment -> Receipt -> Purchase primitive behind a fake|stripe driver seam, plus billing composition, spend gating, credit/wallet, gifting, and a catalog. Consumed directly by splicewire-app and every satellite. Never merchant-of-record.",
    "keywords": [
        "laravel",
        "commerce",
        "payments",
        "stripe",
        "cashier",
        "billing",
        "spatie",
        "laravel-data"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Stephen Rushing",
            "email": "stephen@rushing.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-data": "^4.0|^5.0",
        "rushing/laravel-data-schemas": "dev-main"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "stripe/stripe-php": "^13.0|^14.0|^15.0|^16.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "suggest": {
        "laravel/cashier": "Required only for the `stripe` money-in driver (subscriptions + PaymentIntents). A cost-only tenant using the metering plane does not need it."
    },
    "autoload": {
        "psr-4": {
            "Rushing\\Commerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\Commerce\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Rushing\\Commerce\\CommerceServiceProvider"
            ]
        },
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ]
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/stephenr85/laravel-data-schemas.git"
        },
        {
            "type": "git",
            "url": "https://github.com/stephenr85/laravel-popcorn.git"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "pint": "@php -d memory_limit=512M vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    }
}
